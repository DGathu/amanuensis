// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Resume {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("Untitled Document")
  data      String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}